    </div>
  </div>


  <!-- ========== SCROLL ANIMATION OBSERVER ========== -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const animSel = '.anim-fade-up, .anim-fade-in, .anim-slide-right, .anim-slide-left, .anim-scale-in, .anim-drawer, .anim-seal';
      const animatedElements = document.querySelectorAll(animSel);
      const revealed = new Set();

      function revealElement(el) {
        if (revealed.has(el)) return;
        revealed.add(el);
        el.style.animationPlayState = 'running';
      }

      function revealAll() {
        animatedElements.forEach(el => revealElement(el));
      }

      // Use IntersectionObserver for scroll-triggered animations
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                revealElement(entry.target);
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px 0px 0px' }
        );
        animatedElements.forEach(el => observer.observe(el));
      } else {
        // Fallback for browsers without IntersectionObserver
        revealAll();
      }

      // Safety net: force-reveal ALL content after 3 seconds regardless.
      // This prevents invisible content on mobile if animations/observer fail.
      setTimeout(revealAll, 3000);

      // Hero animations are already running via CSS — no JS override needed

      // Smooth parallax effect on hero background
      const heroImg = document.querySelector('#start > div:first-child img');
      if (heroImg && window.innerWidth > 768) {
        window.addEventListener('scroll', () => {
          const scrollY = window.scrollY;
          if (scrollY < window.innerHeight) {
            heroImg.style.transform = `translateY(${scrollY * 0.15}px) scale(1.05)`;
          }
        }, { passive: true });
      }

      // Navbar shrink on scroll
      const mainNav = document.getElementById('main-nav');
      if (mainNav) {
        const heroSection = document.getElementById('start');
        const heroHeight = heroSection ? heroSection.offsetHeight * 0.3 : 300;
        window.addEventListener('scroll', () => {
          if (window.scrollY > heroHeight) {
            mainNav.classList.add('nav-scrolled');
          } else {
            mainNav.classList.remove('nav-scrolled');
          }
        }, { passive: true });
      }

      // ---- Gallery System ----
      // Load full gallery metadata (titles + descriptions)
      const galleryMeta = JSON.parse(document.getElementById('gallery-meta').textContent);

      // Build gallery items from metadata + file names
      const galleryFileData = JSON.parse(document.getElementById('gallery-files').textContent);
      const galleryItems = galleryMeta.map((m, i) => ({
        src: '/images/gallery/' + galleryFileData[i],
        alt: m.t || '',
        title: m.t || '',
        desc: m.d || '',
      }));

      const previewCards = document.querySelectorAll('.gallery-card');
      const galleryModalCards = document.querySelectorAll('.gallery-modal-card');

      // Elements
      const galleryModal = document.getElementById('gallery-modal');
      const galleryToggle = document.getElementById('gallery-toggle');
      const lightbox = document.getElementById('gallery-lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      const lightboxTitle = document.getElementById('lightbox-title');
      const lightboxDesc = document.getElementById('lightbox-desc');
      const lightboxCounter = document.getElementById('lightbox-counter');
      let currentIdx = 0;
      let lightboxOpenedFromModal = false;

      // --- Gallery Modal (popup with all images) ---
      function openGalleryModal() {
        galleryModal.classList.add('is-active');
        document.body.style.overflow = 'hidden';
      }

      function closeGalleryModal() {
        galleryModal.classList.remove('is-active');
        if (!lightbox.classList.contains('is-active')) {
          document.body.style.overflow = '';
        }
      }

      // "Visa alla bilder" button
      if (galleryToggle) {
        galleryToggle.addEventListener('click', openGalleryModal);
      }

      // Close modal
      document.querySelector('.gallery-modal-backdrop')?.addEventListener('click', closeGalleryModal);
      document.querySelector('.gallery-modal-close')?.addEventListener('click', closeGalleryModal);

      // Click on modal cards -> open lightbox
      galleryModalCards.forEach((card, i) => {
        card.addEventListener('click', () => {
          lightboxOpenedFromModal = true;
          openLightbox(i);
        });
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            lightboxOpenedFromModal = true;
            openLightbox(i);
          }
        });
      });

      // --- Preview cards -> open lightbox directly ---
      previewCards.forEach((card) => {
        const idx = parseInt(card.dataset.galleryIdx);
        card.addEventListener('click', () => {
          lightboxOpenedFromModal = false;
          openLightbox(idx);
        });
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            lightboxOpenedFromModal = false;
            openLightbox(idx);
          }
        });
      });

      // --- Lightbox ---
      function openLightbox(index) {
        currentIdx = index;
        updateLightboxContent(true);
        lightbox.classList.add('is-active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.classList.remove('is-active');
        if (lightboxOpenedFromModal) {
          // Return to gallery modal
          // body overflow stays hidden since modal is still open
        } else {
          document.body.style.overflow = '';
        }
      }

      function updateLightboxContent(immediate) {
        const item = galleryItems[currentIdx];
        if (immediate) {
          lightboxImg.src = item.src;
          lightboxImg.alt = item.alt;
          lightboxImg.style.opacity = '1';
        } else {
          lightboxImg.style.opacity = '0';
          setTimeout(() => {
            lightboxImg.src = item.src;
            lightboxImg.alt = item.alt;
            lightboxImg.style.opacity = '1';
          }, 180);
        }
        const captionEl = document.querySelector('.gallery-lightbox-caption');
        if (item.desc && item.desc.trim()) {
          lightboxTitle.textContent = item.title;
          lightboxDesc.textContent = item.desc;
          captionEl.style.display = '';
        } else {
          captionEl.style.display = 'none';
        }
        lightboxCounter.textContent = (currentIdx + 1) + ' / ' + galleryItems.length;
        // Scroll caption back to top
        if (captionEl) captionEl.scrollTop = 0;
      }

      function lightboxNext() {
        currentIdx = (currentIdx + 1) % galleryItems.length;
        updateLightboxContent(false);
      }

      function lightboxPrev() {
        currentIdx = (currentIdx - 1 + galleryItems.length) % galleryItems.length;
        updateLightboxContent(false);
      }

      // Lightbox controls
      document.querySelector('.gallery-lightbox-close')?.addEventListener('click', closeLightbox);
      document.querySelector('.gallery-lightbox-backdrop')?.addEventListener('click', closeLightbox);
      document.querySelector('.gallery-lightbox-prev')?.addEventListener('click', (e) => { e.stopPropagation(); lightboxPrev(); });
      document.querySelector('.gallery-lightbox-next')?.addEventListener('click', (e) => { e.stopPropagation(); lightboxNext(); });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        // Lightbox has priority
        if (lightbox && lightbox.classList.contains('is-active')) {
          if (e.key === 'Escape') { e.preventDefault(); closeLightbox(); return; }
          if (e.key === 'ArrowRight') { lightboxNext(); return; }
          if (e.key === 'ArrowLeft') { lightboxPrev(); return; }
        }
        // Gallery modal
        if (galleryModal && galleryModal.classList.contains('is-active')) {
          if (e.key === 'Escape') { e.preventDefault(); closeGalleryModal(); return; }
        }
      });

      // Touch swipe support for lightbox
      let touchStartX = 0;
      if (lightbox) {
        lightbox.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });
        lightbox.addEventListener('touchend', (e) => {
          const diff = touchStartX - e.changedTouches[0].screenX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) lightboxNext();
            else lightboxPrev();
          }
        }, { passive: true });
      }

      // ---- Product Modal System ----
      const modal = document.getElementById('product-modal');
      const modalBackdrop = document.getElementById('modal-backdrop');
      const modalCloseBtn = document.getElementById('modal-close');

      function closeModal() {
        modal.classList.remove('modal-active');
        setTimeout(() => {
          document.body.classList.remove('modal-open');
          document.querySelectorAll('.popup-etikett').forEach(el => { el.style.display = 'none'; });
        }, 450);
      }

      window.openModal = function(productId) {
        document.querySelectorAll('.popup-etikett').forEach(el => { el.style.display = 'none'; });
        const content = document.getElementById('modal-content-' + productId);
        if (content) content.style.display = 'block';
        document.body.classList.add('modal-open');
        void modal.offsetHeight;
        modal.classList.add('modal-active');
      };

      if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeModal);
      if (modalBackdrop) modalBackdrop.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('modal-active')) closeModal();
      });
    });
  </script>

</body>
</html>
